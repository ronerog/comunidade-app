# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para ".env" e preencha com seus valores locais.
# O arquivo ".env" é ignorado pelo git (.gitignore). NUNCA commite senhas reais.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=comunidade_user
POSTGRES_PASSWORD=troque_senha_aqui

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=comunidade_rabbit
RABBITMQ_PASS=troque_senha_aqui

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=troque_senha_aqui

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=troque_senha_aqui

# ── Grafana (Fase 8) ──────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
